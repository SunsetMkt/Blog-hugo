{
    "name": "sunset-blog-hugo",
    "description": "Blog refactored.",
    "private": true,
    "devDependencies": {
        "@eslint/css": "^1.1.0",
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^1.2.0",
        "@eslint/markdown": "^8.0.1",
        "@realfavicongenerator/generate-favicon": "^0.8.0",
        "@realfavicongenerator/image-adapter-node": "^0.8.0",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "npm-check-updates": "^21.0.3",
        "pagefind": "^1.5.2",
        "prettier": "^3.8.3",
        "prettier-plugin-go-template": "^0.0.15",
        "prettier-plugin-lint-md": "^1.0.1",
        "prettier-plugin-toml": "^2.0.6",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0",
        "wrangler": "^4.84.0"
    },
    "scripts": {
        "build": "hugo --minify --gc --logLevel info",
        "dev": "hugo server -D -M -O",
        "clean": "rm -r public resources",
        "vercel-install-golang": "dnf install -y golang",
        "cloudflare-pages-build": "git fetch --unshallow && hugo --minify --gc --logLevel info && find public -type f -size +25M -print -exec rm -vf {} \\;",
        "git-unshallow": "git fetch --unshallow",
        "rm-25mb-public": "find public -type f -size +25M -print -exec rm -vf {} \\;",
        "list-public": "find public -type f -printf '%P\n' > public/filelist.txt",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --check",
        "format:fix": "prettier . --write",
        "test": "hugo -M --minify --gc --logLevel info",
        "prepare": "husky",
        "cloudflare-workers-build": "chmod a+x workers_build.sh && ./workers_build.sh",
        "ncu": "npm-check-updates",
        "ncu:fix": "npm-check-updates -u",
        "pagefind": "pagefind",
        "pagefind:dev": "pagefind --serve"
    },
    "engines": {
        "node": ">=22",
        "pnpm": ">=10",
        "npm": ">=10"
    },
    "packageManager": "pnpm@10.30.2",
    "lint-staged": {
        "*.{js,ts,json,md}": [
            "prettier --write"
        ],
        "*.{js,ts}": [
            "eslint --fix"
        ]
    },
    "dependencies": {
        "animate.css": "^4.1.1",
        "canvas-confetti": "^1.9.4",
        "gutenberg-css": "^0.7.0",
        "js-cookie": "^3.0.5",
        "lenis": "^1.3.23",
        "modern-normalize": "^3.0.1",
        "watermark-js-plus": "^1.6.3"
    }
}
